{
  "protocol_version": "mention-detection-development-1",
  "status": "preregistered",
  "scope": {
    "dataset": "data/demo/synthetic_review_cases.json",
    "development_cases": 10,
    "gold_mentions": 30,
    "critical_paraphrases": 5,
    "holdout_used": false,
    "data_policy": "public_and_synthetic_only"
  },
  "candidate_model": {
    "name": "HUMADEX/portugese_medical_ner",
    "revision": "51368a80d5b81aa211199aa1988574869197f288",
    "task": "token-classification",
    "weights_format": "safetensors",
    "accepted_entity_groups": [
      "PROBLEM"
    ],
    "decoding": "BIOES argmax with fast-tokenizer offsets",
    "confidence_threshold": null,
    "model_card": "https://huggingface.co/HUMADEX/portugese_medical_ner",
    "paper": "https://doi.org/10.3390/app15105585"
  },
  "evaluation": {
    "primary_metric": "exact_span_f1",
    "secondary_metrics": [
      "exact_span_precision",
      "exact_span_recall",
      "relaxed_span_f1_iou_0_5",
      "critical_paraphrase_recall",
      "invalid_prediction_rate",
      "latency_mean_ms"
    ],
    "relaxed_iou_threshold": 0.5,
    "linking_metrics_excluded": true,
    "hpo_ranking_excluded": true
  },
  "decision_gate": {
    "exact_span_recall_min": 0.9,
    "exact_span_precision_min": 0.85,
    "critical_paraphrase_recall_min": 0.8,
    "invalid_predictions_max": 0,
    "dashboard_promotion": false
  },
  "execution": {
    "download_only_required_model_files": true,
    "local_files_only_after_download": true,
    "record_model_sha256": true,
    "single_fixed_configuration": true,
    "holdout_execution": false
  },
  "limitations": [
    "Exploratory development protocol, not a clinical validation.",
    "The model is weakly supervised and its published metrics do not transfer to this dataset.",
    "The model detects broad PROBLEM mentions and does not assign HPO identifiers.",
    "No diagnostic use or claim of statistical superiority is permitted."
  ]
}
